{
  "name": "hoardly",
  "version": "1.0.0",
  "description": "AI-powered bookmark manager for Chrome.",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "dev": "wxt",
    "dev:h5": "vite --host 127.0.0.1 --port 5173",
    "postinstall": "wxt prepare",
    "build": "wxt zip && bash scripts/copy-extension-to-desktop.sh",
    "build:h5": "vite build",
    "build:all": "npm run build && npm run build:h5 && bash scripts/copy-extension-to-desktop.sh",
    "pages:deploy": "npm run build:h5 && npx wrangler pages deploy dist --project-name=hoardly-app --branch=main",
    "preview:h5": "vite preview --host 127.0.0.1 --port 4173",
    "chrome:open": "bash scripts/open-chrome-with-hoardly.sh",
    "zip": "wxt zip && bash scripts/copy-extension-to-desktop.sh",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "UNLICENSED",
  "private": true,
  "type": "module",
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@fontsource-variable/inter": "^5.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "linkedom": "^0.18.12",
    "lucide-react": "^1.14.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "shadcn": "^4.6.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@types/chrome": "^0.1.40",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@wxt-dev/module-react": "^1.2.2",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "wxt": "^0.20.25"
  }
}
